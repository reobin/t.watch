{
  "name": "thud.sh",
  "version": "0.15.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reobin/thud.sh.git"
  },
  "bin": {
    "thud": "dist/index.js",
    "thud-codex-status": "integrations/codex/thud-sh-status.ts",
    "thud.sh": "dist/index.js"
  },
  "files": [
    "dist",
    "integrations/codex/thud-sh-status.ts",
    "integrations/opencode/thud-sh-status.ts",
    "README.md"
  ],
  "type": "module",
  "exports": {
    "./codex-status": "./integrations/codex/thud-sh-status.ts",
    "./server": "./integrations/opencode/thud-sh-status.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --external=@opentui/core --outdir=dist && chmod +x dist/index.js",
    "prepack": "bun run build",
    "check": "concurrently --kill-others-on-fail --success all \"bun run lint.check\" \"bun run format.check\" \"bun run tc\" \"bun run test\"",
    "check.fix": "bun run lint && bun run format && bun run check",
    "lint": "oxlint --fix .",
    "lint.check": "oxlint .",
    "format": "oxfmt --write .",
    "format.check": "oxfmt --check .",
    "tc": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@opentui/core": "^0.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
